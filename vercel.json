{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@3.12",
      "memory": 1024,
      "maxDuration": 15,
      "includeFiles": "models/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/api/index.py"
    }
  ]
}